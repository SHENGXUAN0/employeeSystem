<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.employeesystem.mapper.DeptMapper">
    <select id="selectAll" resultType="org.example.employeesystem.entity.Dept">
        select * from dept
    </select>
    <insert id="insert" parameterType="org.example.employeesystem.entity.Dept">
        insert into dept(name) values(#{name})
    </insert>
    <update id="update" parameterType="org.example.employeesystem.entity.Dept">
        update dept set name = (#{name}) where id = (#{id})
    </update>
    <delete id="deleteById">
        delete from dept where id = #{id}
    </delete>
    
    
    
</mapper>