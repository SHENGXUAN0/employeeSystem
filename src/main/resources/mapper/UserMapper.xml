<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.employeesystem.mapper.UserMapper">
    <select id="login" resultType="org.example.employeesystem.entity.User">
        select * from user_sys where username = #{username} and password = #{password}
    </select>
    <insert id="register" parameterType="org.example.employeesystem.entity.User">
        insert into user_sys(username,password,role)Values(#{username},#{password},#{role})
    </insert>
</mapper>